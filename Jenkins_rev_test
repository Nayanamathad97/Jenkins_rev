    choice(name: "BRANCH", choices: ['test','prod','stage'], description: 'choose environment to deploy')
  }
    stages
    {
        stage('STAGE1')
        {
            steps
            {
                echo "NAME:${params.NAME}"
                echo "SKIP_TEST:${params.SKIP_TEST}"
                echo "NAME:${params.BRANCH}"

                sh '''
                echo "NAME: ${NAME}"
                echo "SKIP_TEST: ${SKIP_TEST}"
                echo "BRANCH: ${BRANCH}"
                '''                
            }
        }
    }
}